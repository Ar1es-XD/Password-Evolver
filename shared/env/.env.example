# Shared environment defaults
EVOLVER_LOG_LEVEL=INFO
EVOLVER_UPDATE_EVERY=50
EVOLVER_STEP_DELAY=0.0
EVOLVER_DEFAULT_CHARSET=ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz1234567890 _+=~!@#$%^&*(){}[]|;:<>,.?/
EVOLVER_MAX_TARGET_LENGTH=256
EVOLVER_MAX_CHARSET_LENGTH=512
EVOLVER_MAX_BODY_BYTES=4096
EVOLVER_MAX_ACTIVE_SIMULATIONS=200
EVOLVER_RATE_LIMIT_RPS=10
EVOLVER_RATE_LIMIT_BURST=20
EVOLVER_WEBSOCKET_HEARTBEAT_INTERVAL=15
EVOLVER_WEBSOCKET_MAX_MISSED=3
EVOLVER_OTEL_ENABLED=false
EVOLVER_OTEL_ENDPOINT=http://localhost:4317
EVOLVER_OTEL_SERVICE_NAME=password-evolver
EVOLVER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/password_evolver
EVOLVER_REDIS_URL=redis://localhost:6379/0
EVOLVER_REDIS_CHANNEL_PREFIX=simulation:
EVOLVER_CELERY_BROKER_URL=redis://localhost:6379/0
EVOLVER_CELERY_RESULT_BACKEND=redis://localhost:6379/0
EVOLVER_DB_POOL_SIZE=5
EVOLVER_DB_MAX_OVERFLOW=10
EVOLVER_AUTO_CREATE_TABLES=false
EVOLVER_WORKER_HEARTBEAT_INTERVAL=10
EVOLVER_WORKER_HEARTBEAT_CHANNEL=workers:heartbeat
EVOLVER_WORKER_METRICS_PUSHGATEWAY=
EVOLVER_WORKER_METRICS_JOB=password-evolver-worker

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/api/v1
